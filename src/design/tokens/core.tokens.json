{
  "color": {
    "teal": {
      "100": { "$type": "color", "$value": "#D9EEEA" },
      "500": { "$type": "color", "$value": "#14B8A6" },
      "700": { "$type": "color", "$value": "#0F766E" },
      "800": { "$type": "color", "$value": "#115E59" }
    },
    "neutral": {
      "0": { "$type": "color", "$value": "#FFFFFF" },
      "50": { "$type": "color", "$value": "#F7F8F5" },
      "100": { "$type": "color", "$value": "#EEF2EF" },
      "200": { "$type": "color", "$value": "#DCE2DE" },
      "400": { "$type": "color", "$value": "#AAB5AF" },
      "600": { "$type": "color", "$value": "#5F6B66" },
      "800": { "$type": "color", "$value": "#1F2933" },
      "900": { "$type": "color", "$value": "#17201D" }
    },
    "canvas": {
      "well": { "$type": "color", "$value": "#E7E3DA" }
    },
    "red": {
      "700": { "$type": "color", "$value": "#B42318" }
    },
    "amber": {
      "700": { "$type": "color", "$value": "#9A5B13" }
    }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "0.25rem" },
    "2": { "$type": "dimension", "$value": "0.5rem" },
    "3": { "$type": "dimension", "$value": "0.75rem" },
    "4": { "$type": "dimension", "$value": "1rem" },
    "5": { "$type": "dimension", "$value": "1.5rem" },
    "6": { "$type": "dimension", "$value": "2rem" },
    "7": { "$type": "dimension", "$value": "3rem" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "8px" },
    "md": { "$type": "dimension", "$value": "10px" },
    "lg": { "$type": "dimension", "$value": "12px" },
    "sheet": { "$type": "dimension", "$value": "18px" }
  },
  "shadow": {
    "panel": { "$type": "shadow", "$value": "0 12px 32px rgb(31 41 51 / 10%)" }
  },
  "duration": {
    "fast": { "$type": "duration", "$value": "120ms" },
    "stage": { "$type": "duration", "$value": "180ms" }
  },
  "font": {
    "sans": {
      "$type": "fontFamily",
      "$value": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif"
    },
    "mono": {
      "$type": "fontFamily",
      "$value": "'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace"
    }
  },
  "layout": {
    "headerHeight": { "$type": "dimension", "$value": "3.5rem" },
    "safeBottom": { "$type": "string", "$value": "env(safe-area-inset-bottom, 0px)" }
  }
}
